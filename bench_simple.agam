@lang.advance

// ══════════════════════════════════════════════
// Agam Benchmark — Simple C-compilable benchmark
// Tests: Arithmetic loop, Print
// ══════════════════════════════════════════════

fn main() -> i32 {
    let mut total: i32 = 0;
    let mut i: i32 = 0;
    while i < 100000000 {
        total = total + i;
        i = i + 1;
    }
    print(total);
    return 0;
}
