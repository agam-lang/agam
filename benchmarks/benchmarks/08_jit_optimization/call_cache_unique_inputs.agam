@lang.advance

fn hot(n: i64) -> i64 {
    let total: i64 = 0;
    let i: i64 = 0;
    while i < 520 {
        total = total + ((n * 37) + (i * 19) + ((n + i) % 23)) % 1423;
        i = i + 1;
    }
    return total;
}

fn main() -> i32 {
    let acc: i64 = 0;
    let i: i64 = 0;
    while i < 350000 {
        acc = acc + hot(i);
        i = i + 1;
    }
    print_int(acc);
    return 0;
}
